# ============================================================
# .env de PRODUÇÃO — DokeHost VPS (tudo no mesmo servidor)
# Copie este arquivo para o servidor como: /opt/aios/.env
# NUNCA commite no git!
# ============================================================

NODE_ENV=production
PORT=3001

# ── Banco de Dados ────────────────────────────────────────────
DB_USER=aios
DB_PASS=TROQUE_POR_SENHA_FORTE_123!
DB_NAME=aios_db

# ── JWT ───────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=COLE_AQUI_SUA_CHAVE_JWT_LONGA_E_ALEATORIA

# ── URLs públicas do servidor ─────────────────────────────────
# Use o IP do seu servidor DokeHost (ou domínio se tiver)
# Exemplo com IP:    http://179.X.X.X
# Exemplo com domínio: https://app.capitalPrime.com.br
PUBLIC_URL=http://SEU_IP_DOKEHOST
PUBLIC_WS_URL=ws://SEU_IP_DOKEHOST

# ── CORS — permite que o dashboard (mesma máquina) acesse o backend
CORS_ORIGINS=http://SEU_IP_DOKEHOST,http://SEU_IP_DOKEHOST:3000,chrome-extension://

# ── Segurança ─────────────────────────────────────────────────
WEBHOOK_SECRET=CRIE_UM_SECRET_ALEATORIO_AQUI

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=COLE_64_CHARS_HEX_AQUI

# ── Asaas (configurado pelo painel de cada usuário) ───────────
ASAAS_BASE_URL=https://api.asaas.com/v3
